# Environment variables for Sibyl
# Copy this file to .env and fill in your values

# WalletConnect Project ID (get one free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=

# Contract addresses (Kite Testnet)
NEXT_PUBLIC_PULSE_SCORE_ADDRESS=0x4Cf4Ca414616Dad1CCc76015Ee24A5DB53f06b04
NEXT_PUBLIC_USDC_ADDRESS=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63

# Kite Testnet RPC
NEXT_PUBLIC_KITE_RPC_URL=https://rpc-testnet.gokite.ai

# Deployer private key (only needed for contract deployment scripts)
DEPLOYER_PRIVATE_KEY=
